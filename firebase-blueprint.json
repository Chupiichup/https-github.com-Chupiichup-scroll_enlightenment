{
  "entities": {
    "Board": {
      "title": "Board",
      "description": "A Kanban board for organizing tasks",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The name of the board" },
        "background": { "type": "string", "description": "Background style or color" },
        "ownerId": { "type": "string", "description": "UID of the board owner" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "ownerId"]
    },
    "Column": {
      "title": "Column",
      "description": "A list or column within a board",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "boardId": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "boardId", "order"]
    },
    "Task": {
      "title": "Task",
      "description": "A card or task within a column",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "columnId": { "type": "string" },
        "boardId": { "type": "string" },
        "order": { "type": "number" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High", "Urgent"] },
        "deadline": { "type": "string", "format": "date-time" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "checklist": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "completed": { "type": "boolean" }
            }
          }
        },
        "progress": { "type": "number" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "columnId", "boardId", "order", "ownerId"]
    }
  },
  "firestore": {
    "/boards/{boardId}": { "schema": "Board", "description": "User boards" },
    "/boards/{boardId}/columns/{columnId}": { "schema": "Column", "description": "Columns in a board" },
    "/boards/{boardId}/tasks/{taskId}": { "schema": "Task", "description": "Tasks in a board" }
  }
}
