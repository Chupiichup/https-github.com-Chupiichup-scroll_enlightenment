{
  "entities": {
    "Column": {
      "title": "Column",
      "description": "A list or column within a board",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "ownerId": { "type": "string" },
        "order": { "type": "number" },
        "color": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "ownerId", "order"]
    },
    "Task": {
      "title": "Task",
      "description": "A card or task within a column",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "columnId": { "type": "string" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High", "Urgent"] },
        "deadline": { "type": "string", "format": "date-time" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "checklist": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "completed": { "type": "boolean" }
            }
          }
        },
        "progress": { "type": "number" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "columnId", "ownerId"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A hierarchical goal (Year -> Quarter -> Month -> Week)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "level": { "type": "string", "enum": ["year", "quarter", "month", "week"] },
        "parentId": { "type": "string" },
        "targetValue": { "type": "number" },
        "currentValue": { "type": "number" },
        "unit": { "type": "string" },
        "updateMethod": { "type": "string", "enum": ["manual", "task-linked"] },
        "linkedTaskIds": { "type": "array", "items": { "type": "string" } },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "ownerId", "level", "targetValue", "unit", "updateMethod"]
    }
  },
  "firestore": {
    "/columns/{columnId}": { "schema": "Column", "description": "User columns" },
    "/tasks/{taskId}": { "schema": "Task", "description": "User tasks" },
    "/goals/{goalId}": { "schema": "Goal", "description": "User goals" }
  }
}
